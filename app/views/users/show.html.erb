<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
  <div class="flex justify-between items-center">
    <div>
      <p class="font-bold text-xl text-gray-900"><%= @user.name %></p>
      <p class="text-gray-500 text-sm"><%= @user.email %></p>
    </div>
    <% if @user == current_user %>
      <%= link_to "Edit Profile", edit_user_path(@user), class: "text-xs text-blue-400 border border-blue-200 px-3 py-1 rounded hover:bg-blue-50 transition" %>
    <% end %>
  </div>
</div>

<h2 class="text-lg font-semibold text-gray-700 mb-4">Posts</h2>

<% @posts.each do |post| %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-4">
    <div class="flex justify-between items-start mb-3">
      <div class="flex items-center gap-4 text-sm text-gray-400">
        <span><%= post.created_at.strftime("%b %d, %Y") %></span>
        <span><%= post.likes.count %> likes</span>
      </div>
      <% if @user == current_user %>
        <div class="flex gap-2">
          <%= link_to "Edit", edit_post_path(post), class: "text-xs text-blue-400 border border-blue-200 px-3 py-1 rounded hover:bg-blue-50 transition" %>
          <%= button_to "Delete", post, method: :delete, class: "text-xs text-red-400 border border-red-200 px-3 py-1 rounded hover:bg-red-50 transition bg-transparent cursor-pointer" %>
        </div>
      <% end %>
    </div>
    <p class="text-gray-800 mb-3"><%= post.content %></p>
    <% if post.image.attached? %>
      <%= image_tag post.image, class: "rounded-lg w-full object-cover max-h-96 mb-3" %>
    <% end %>
  </div>
<% end %>