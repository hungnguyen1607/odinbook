<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
  <p class="font-bold text-xl text-gray-900"><%= @user.name %></p>
  <p class="text-gray-500 text-sm"><%= @user.email %></p>
</div>

<h2 class="text-lg font-semibold text-gray-700 mb-4">Posts</h2>

<% @posts.each do |post| %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-4">
    <p class="text-gray-800 mb-3"><%= post.content %></p>
    <% if post.image.attached? %>
      <%= image_tag post.image, class: "rounded-lg w-full object-cover max-h-96 mb-3" %>
    <% end %>
    <div class="flex items-center gap-4 text-sm text-gray-400">
      <span><%= post.created_at.strftime("%b %d, %Y") %></span>
      <span><%= post.likes.count %> likes</span>
    </div>
  </div>
<% end %>