<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
  <h1 class="text-lg font-semibold mb-4">Edit Profile</h1>
  <%= form_with model: @user, url: user_path(@user), method: :patch, local: true do |f| %>
    <div class="mb-4">
      <%= f.label :name, class: "block text-sm text-gray-600 mb-1" %>
      <%= f.text_field :name, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" %>
    </div>
    <%= f.submit "Save", class: "bg-blue-500 text-white px-4 py-2 rounded text-sm hover:bg-blue-600 transition cursor-pointer" %>
  <% end %>
</div>