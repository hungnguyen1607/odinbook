<div class="max-w-md mx-auto mt-16 bg-white p-8 rounded-lg border border-gray-200">
  <h2 class="text-xl font-semibold mb-6">Log in</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "block text-sm text-gray-600 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-sm text-gray-600 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" %>
    </div>

    <div class="mb-4 flex items-center gap-2 text-sm text-gray-600">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me %>
    </div>

    <%= f.submit "Log in", class: "w-full bg-blue-500 text-white py-2 rounded text-sm hover:bg-blue-600 transition cursor-pointer" %>
  <% end %>

  <div class="mt-4 text-sm text-gray-500 flex flex-col gap-1">
    <%= render "devise/shared/links" %>
  </div>
</div>