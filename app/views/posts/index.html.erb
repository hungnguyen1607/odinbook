<div class="flex justify-between items-center mb-6">
  <h1 class="text-xl font-semibold">Feed</h1>
  <%= link_to "New Post", new_post_path, class: "text-sm bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition" %>
</div>

<% @posts.each do |post| %>
  <div class="bg-white border border-gray-200 rounded-lg p-5 mb-4">
    <div class="flex justify-between items-start mb-3">
      <div>
        <%= link_to post.user.name, user_path(post.user), class: "font-medium text-sm hover:text-blue-500 transition" %>
        <p class="text-xs text-gray-400"><%= post.created_at.strftime("%b %d, %Y") %></p>
      </div>
      <% if post.user == current_user %>
        <div class="flex gap-2 items-center">
          <%= link_to "Edit", edit_post_path(post), class: "text-xs text-blue-400 border border-blue-200 px-3 py-1 rounded hover:bg-blue-50 transition" %>
          <%= button_to "Delete", post, method: :delete, class: "text-xs text-red-400 border border-red-200 px-3 py-1 rounded hover:bg-red-50 transition bg-transparent cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <p class="text-sm text-gray-800 mb-4"><%= post.content %></p>
    <% if post.image.attached? %>
      <%= image_tag post.image, class: "rounded-lg w-full object-cover max-h-96 mb-4" %>
    <% end %>
    <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
      <% if post.likes.exists?(user: current_user) %>
        <%= button_to "Unlike", post_like_path(post, post.likes.find_by(user: current_user)), method: :delete, class: "text-blue-500 bg-transparent border-0 cursor-pointer text-xs" %>
      <% else %>
        <%= button_to "Like", post_likes_path(post), method: :post, class: "bg-transparent border-0 cursor-pointer text-xs hover:text-blue-500 transition" %>
      <% end %>
      <span><%= post.likes.count %> likes</span>
    </div>

    <div class="border-t border-gray-100 pt-3 mb-3">
      <% post.comments.each do |comment| %>
        <p class="text-xs text-gray-700 mb-1"><span class="font-medium"><%= comment.user.name %></span>: <%= comment.body %></p>
      <% end %>
    </div>
    <%= form_with model: [@post = post, Comment.new], local: true, class: "flex gap-2" do |f| %>
      <%= f.text_field :body, placeholder: "Add a comment...", class: "flex-1 border border-gray-200 rounded px-3 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-blue-400" %>
      <%= f.submit "Post", class: "text-xs bg-gray-100 px-3 py-1 rounded hover:bg-gray-200 transition cursor-pointer" %>
    <% end %>
  </div>
<% end %>