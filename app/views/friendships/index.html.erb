<h1 class="text-xl font-semibold mb-6">Friend Requests</h1>

<% if @pending_requests.empty? %>
  <p class="text-sm text-gray-400">No pending requests.</p>
<% end %>

<% @pending_requests.each do |friendship| %>
  <div class="bg-white border border-gray-200 rounded-lg p-4 mb-3 flex justify-between items-center">
    <p class="text-sm font-medium"><%= friendship.requester.name %> sent you a friend request</p>
    <div class="flex gap-2">
      <%= button_to "Accept", friendship_path(friendship), method: :patch,
          class: "text-xs bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 transition cursor-pointer" %>
      <%= button_to "Decline", friendship_path(friendship), method: :delete,
          class: "text-xs border border-gray-200 px-3 py-1 rounded hover:bg-gray-100 transition cursor-pointer" %>
    </div>
  </div>
<% end %>